# ─── Database (Supabase) ───────────────────────────────────────────
# Settings → Database → Connection string v Supabase dashboardu.
#
# DATABASE_URL = "Connection pooling" string (port 6543, pgbouncer=true)
#   → použij tuto pro běžící appku (Render web service), šetří connections.
# DIRECT_URL = "Direct connection" string (port 5432)
#   → použij tuto pro migrace (prisma migrate deploy), bypassuje pooler.
DATABASE_URL="postgresql://postgres.xxxxx:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.xxxxx:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# ─── NextAuth ───────────────────────────────────────────────────────
# NEXTAUTH_URL musí být přesná veřejná URL tvé Render služby (bez lomítka na konci).
# Na Renderu: https://cinemax.onrender.com  (nebo vlastní doména)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="vygeneruj pomoci: openssl rand -base64 32"

# ─── TMDb API ───────────────────────────────────────────────────────
TMDB_API_KEY="your-tmdb-api-key"
TMDB_ACCESS_TOKEN="your-tmdb-read-access-token"

# ─── YouTube Data API v3 ────────────────────────────────────────────
YOUTUBE_API_KEY="your-youtube-api-key"

# ─── Cloudinary (volitelné — pro vlastní upload plakátů) ───────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"
